export component SidebarEntry inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    callback clicked;

    border-radius: 12px;
    background: touch.pressed ? #352d5a : touch.has-hover ? (root.active ? #312954 : #202636) : (root.active ? #2a2446 : #00000000);

    Image {
        x: 18px;
        y: parent.height * 0.5 - self.height * 0.5;
        width: 20px;
        height: 20px;
        source: root.icon;
        colorize: root.active ? #f7f8ff : #d4d9e7;
    }

    Text {
        x: 56px;
        y: 0;
        width: parent.width - 72px;
        height: parent.height;
        text: root.label;
        color: root.active ? #f3f5fb : #d4d9e7;
        font-size: 14px;
        font-weight: 500;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                root.clicked();
            }
        }
    }
}

export component HeaderButton inherits Rectangle {
    in property <string> symbol;
    in property <bool> close-accent: false;
    callback clicked;

    background: touch.has-hover ? (root.close-accent ? #722536 : #252c3b) : #00000000;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.symbol;
        color: #edf1ff;
        font-size: 16px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

export component HotkeyChip inherits Rectangle {
    in property <string> value;
    in property <bool> align-right: false;
    in property <bool> align-center: false;

    border-radius: 10px;
    border-width: 1px;
    border-color: #30384a;
    background: #1a2030;

    Text {
        x: 14px;
        width: parent.width - 28px;
        height: parent.height;
        text: root.value;
        color: #edf1ff;
        font-size: 15px;
        font-weight: 500;
        horizontal-alignment: root.align-center ? center : root.align-right ? right : left;
        vertical-alignment: center;
    }
}

export component IconActionButton inherits Rectangle {
    callback clicked;

    border-radius: 10px;
    border-width: 1px;
    border-color: #30384a;
    background: touch.pressed ? #242b3c : touch.has-hover ? #20283a : #1b2232;

    Image {
        source: @image-url("../icons/edit.svg");
        image-fit: contain;
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

export component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;

    border-radius: self.height * 0.5;
    background: root.checked ? #6f4cf6 : #252c3b;

    Rectangle {
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        width: parent.height - 6px;
        height: parent.height - 6px;
        border-radius: self.width * 0.5;
        background: #ffffff;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.checked = !root.checked;
        }
    }
}

export component DialogButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> action-enabled: true;
    callback clicked;

    border-radius: 12px;
    border-width: 1px;
    border-color: root.primary ? #7b5cff : #394153;
    background: !root.action-enabled ? #141925 : touch.pressed ? (root.primary ? #8362ff : #242c3c) : touch.has-hover ? (root.primary ? #7a59ff : #202838) : (root.primary ? #6f4cf6 : #1a2030);
    opacity: root.action-enabled ? 1 : 0.5;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f5f7ff;
        font-size: 15px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.action-enabled;
        clicked => {
            root.clicked();
        }
    }
}

import { HeaderButton, SidebarEntry } from "components/common.slint";
import { ShortcutEditorDialog } from "dialogs/shortcut_editor.slint";
import { AboutPage } from "pages/about_page.slint";
import { SettingsPage } from "pages/settings_page.slint";

export struct ShortcutAction {
    label: string,
    shortcut: string,
}

export component AppWindow inherits Window {
    title: "SwitchLayout";
    width: 1120px;
    height: 720px;
    no-frame: true;
    background: #111623;

    in-out property <[ShortcutAction]> shortcut-actions: [
        { label: "Последнее слово", shortcut: "Ctrl + Alt + 1" },
        { label: "Весь текст", shortcut: "Ctrl + Alt + 2" },
    ];
    in-out property <bool> autostart-enabled: true;
    in-out property <int> editing-index: -1;
    in-out property <string> editing-label: "Последнее слово";
    in-out property <string> pending-shortcut: "Ctrl + Alt + 1";
    in-out property <bool> pending-shortcut-valid: true;
    in-out property <int> current-tab: 0;
    in property <string> app-name: "SwitchLayout";
    in property <string> app-version: "v1.0.0";

    callback request-edit(int);
    callback cancel-edit();
    callback accept-edit();
    callback autostart-toggled(bool);
    callback select-tab(int);
    callback begin-window-drag();
    callback request-minimize();
    callback request-close();

    property <length> titlebar-height: 44px;
    property <length> sidebar-width: 246px;
    property <length> content-padding-x: 46px;
    property <length> content-top: 30px;

    changed autostart-enabled => {
        root.autostart-toggled(root.autostart-enabled);
    }

    Rectangle {
        background: #111623;

        panel := Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            border-width: 1px;
            border-color: #2c3241;
            background: #111623;
            clip: true;

            titlebar := Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: root.titlebar-height;
                background: #151a26;

                drag-area := TouchArea {
                    x: 0;
                    y: 0;
                    width: parent.width - 92px;
                    height: parent.height;
                    mouse-cursor: default;

                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.begin-window-drag();
                        }
                    }
                }

                Rectangle {
                    x: 16px;
                    y: 9px;
                    width: 26px;
                    height: 26px;
                    border-radius: 8px;
                    background: #5d49c6;

                    Image {
                        x: 5px;
                        y: 5px;
                        width: 16px;
                        height: 16px;
                        source: @image-url("icons/app.svg");
                    }
                }

                Text {
                    x: 56px;
                    y: 0;
                    width: 180px;
                    height: parent.height;
                    text: root.app-name;
                    color: #f8f9ff;
                    font-size: 15px;
                    font-weight: 500;
                    vertical-alignment: center;
                }

                HeaderButton {
                    x: parent.width - 88px;
                    y: 0;
                    width: 44px;
                    height: parent.height;
                    symbol: "−";
                    clicked => {
                        root.request-minimize();
                    }
                }

                HeaderButton {
                    x: parent.width - 44px;
                    y: 0;
                    width: 44px;
                    height: parent.height;
                    symbol: "×";
                    close-accent: true;
                    clicked => {
                        root.request-close();
                    }
                }

                Rectangle {
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: #2c3241;
                }
            }

            sidebar := Rectangle {
                x: 0;
                y: root.titlebar-height;
                width: root.sidebar-width;
                height: parent.height - root.titlebar-height;
                background: #171c29;

                SidebarEntry {
                    x: 12px;
                    y: 16px;
                    width: parent.width - 24px;
                    height: 50px;
                    icon: @image-url("icons/gear.svg");
                    label: "Настройки";
                    active: root.current-tab == 0;
                    clicked => {
                        root.select-tab(0);
                    }
                }

                SidebarEntry {
                    x: 12px;
                    y: 76px;
                    width: parent.width - 24px;
                    height: 50px;
                    icon: @image-url("icons/info.svg");
                    label: "О приложении";
                    active: root.current-tab == 1;
                    clicked => {
                        root.select-tab(1);
                    }
                }

                Text {
                    x: 32px;
                    y: parent.height - 44px;
                    width: 90px;
                    height: 20px;
                    text: root.app-version;
                    color: #c7cddd;
                    font-size: 14px;
                }

                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: #2c3241;
                }
            }

            content := Rectangle {
                x: root.sidebar-width;
                y: root.titlebar-height;
                width: parent.width - root.sidebar-width;
                height: parent.height - root.titlebar-height;
                background: #121825;

                SettingsPage {
                    visible: root.current-tab == 0;
                    width: parent.width;
                    height: parent.height;
                    first-action-label: root.shortcut-actions[0].label;
                    first-shortcut-text: root.shortcut-actions[0].shortcut;
                    second-action-label: root.shortcut-actions[1].label;
                    second-shortcut-text: root.shortcut-actions[1].shortcut;
                    autostart-enabled <=> root.autostart-enabled;
                    content-padding-x: root.content-padding-x;
                    content-top: root.content-top;
                    request-edit(index) => {
                        root.request-edit(index);
                    }
                }

                AboutPage {
                    visible: root.current-tab == 1;
                    width: parent.width;
                    height: parent.height;
                    app-name: root.app-name;
                    app-version: root.app-version;
                    content-padding-x: root.content-padding-x;
                    content-top: root.content-top;
                }
            }
        }

        ShortcutEditorDialog {
            x: panel.x;
            y: panel.y;
            width: panel.width;
            height: panel.height;
            editing-index: root.editing-index;
            editing-label: root.editing-label;
            pending-shortcut: root.pending-shortcut;
            pending-shortcut-valid: root.pending-shortcut-valid;
            cancel-edit => {
                root.cancel-edit();
            }
            accept-edit => {
                root.accept-edit();
            }
        }
    }
}

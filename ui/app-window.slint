export struct ShortcutAction {
    label: string,
    shortcut: string,
}

component SidebarEntry inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    callback clicked;

    border-radius: 12px;
    background: touch.pressed ? #352d5a : touch.has-hover ? (root.active ? #312954 : #202636) : (root.active ? #2a2446 : #00000000);

    Image {
        x: 18px;
        y: parent.height * 0.5 - self.height * 0.5;
        width: 20px;
        height: 20px;
        source: root.icon;
        colorize: root.active ? #f7f8ff : #d4d9e7;
    }

    Text {
        x: 56px;
        y: 0;
        width: parent.width - 72px;
        height: parent.height;
        text: root.label;
        color: root.active ? #f3f5fb : #d4d9e7;
        font-size: 14px;
        font-weight: 500;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                root.clicked();
            }
        }
    }
}

component HeaderButton inherits Rectangle {
    in property <string> symbol;
    in property <bool> close-accent: false;
    callback clicked;

    background: touch.has-hover ? (root.close-accent ? #722536 : #252c3b) : #00000000;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.symbol;
        color: #edf1ff;
        font-size: 16px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component HotkeyChip inherits Rectangle {
    in property <string> value;

    border-radius: 10px;
    border-width: 1px;
    border-color: #30384a;
    background: #1a2030;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.value;
        color: #edf1ff;
        font-size: 15px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component IconActionButton inherits Rectangle {
    callback clicked;

    border-radius: 10px;
    border-width: 1px;
    border-color: #30384a;
    background: touch.pressed ? #242b3c : touch.has-hover ? #20283a : #1b2232;

    Image {
        source: @image-url("icons/edit.svg");
        image-fit: contain;
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component ShortcutRow inherits Rectangle {
    in property <string> action-label;
    in property <string> shortcut-text;
    in property <bool> show-top-divider: false;
    callback edit-requested;

    Rectangle {
        visible: root.show-top-divider;
        x: 0;
        y: 0;
        width: parent.width;
        height: 1px;
        background: #2c3445;
    }

    Text {
        x: 26px;
        y: 0;
        width: 240px;
        height: parent.height;
        text: root.action-label;
        color: #ffffff;
        font-size: 14px;
        font-weight: 500;
        vertical-alignment: center;
    }

    HotkeyChip {
        x: parent.width - self.width - 74px;
        y: parent.height * 0.5 - self.height * 0.5;
        width: 186px;
        height: 40px;
        value: root.shortcut-text;
    }

    IconActionButton {
        x: parent.width - self.width - 24px;
        y: parent.height * 0.5 - self.height * 0.5;
        width: 40px;
        height: 40px;
        clicked => {
            root.edit-requested();
        }
    }
}

component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;

    border-radius: self.height * 0.5;
    background: root.checked ? #6f4cf6 : #252c3b;

    Rectangle {
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        width: parent.height - 6px;
        height: parent.height - 6px;
        border-radius: self.width * 0.5;
        background: #ffffff;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.checked = !root.checked;
        }
    }
}

component DialogButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> action-enabled: true;
    callback clicked;

    border-radius: 12px;
    border-width: 1px;
    border-color: root.primary ? #7b5cff : #394153;
    background: !root.action-enabled ? #141925 : touch.pressed ? (root.primary ? #8362ff : #242c3c) : touch.has-hover ? (root.primary ? #7a59ff : #202838) : (root.primary ? #6f4cf6 : #1a2030);
    opacity: root.action-enabled ? 1 : 0.5;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f5f7ff;
        font-size: 15px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.action-enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    title: "SwitchLayout";
    width: 1120px;
    height: 720px;
    no-frame: true;
    background: #111623;

    in-out property <[ShortcutAction]> shortcut-actions: [
        { label: "Последнее слово", shortcut: "Ctrl + Alt + 1" },
        { label: "Весь текст", shortcut: "Ctrl + Alt + 2" },
    ];
    in-out property <bool> autostart-enabled: true;
    in-out property <int> editing-index: -1;
    in-out property <string> editing-label: "Последнее слово";
    in-out property <string> pending-shortcut: "Ctrl + Alt + 1";
    in-out property <bool> pending-shortcut-valid: true;
    in-out property <int> current-tab: 0;
    in property <string> app-name: "SwitchLayout";
    in property <string> app-version: "v1.0.0";

    callback request-edit(int);
    callback cancel-edit();
    callback accept-edit();
    callback capture-shortcut(string, bool, bool, bool, bool);
    callback select-tab(int);
    callback begin-window-drag();
    callback request-minimize();
    callback request-close();

    property <length> titlebar-height: 44px;
    property <length> sidebar-width: 246px;
    property <length> content-padding-x: 46px;
    property <length> content-top: 30px;

    Rectangle {
        background: #111623;

        panel := Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            border-width: 1px;
            border-color: #2c3241;
            background: #111623;
            clip: true;

            titlebar := Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: root.titlebar-height;
                background: #151a26;

                drag-area := TouchArea {
                    x: 0;
                    y: 0;
                    width: parent.width - 92px;
                    height: parent.height;
                    mouse-cursor: default;

                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.begin-window-drag();
                        }
                    }
                }

                Rectangle {
                    x: 16px;
                    y: 9px;
                    width: 26px;
                    height: 26px;
                    border-radius: 8px;
                    background: #5d49c6;

                    Image {
                        x: 5px;
                        y: 5px;
                        width: 16px;
                        height: 16px;
                        source: @image-url("icons/app.svg");
                    }
                }

                Text {
                    x: 56px;
                    y: 0;
                    width: 180px;
                    height: parent.height;
                    text: root.app-name;
                    color: #f8f9ff;
                    font-size: 15px;
                    font-weight: 500;
                    vertical-alignment: center;
                }

                HeaderButton {
                    x: parent.width - 88px;
                    y: 0;
                    width: 44px;
                    height: parent.height;
                    symbol: "−";
                    clicked => {
                        root.request-minimize();
                    }
                }

                HeaderButton {
                    x: parent.width - 44px;
                    y: 0;
                    width: 44px;
                    height: parent.height;
                    symbol: "×";
                    close-accent: true;
                    clicked => {
                        root.request-close();
                    }
                }

                Rectangle {
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: #2c3241;
                }
            }

            sidebar := Rectangle {
                x: 0;
                y: root.titlebar-height;
                width: root.sidebar-width;
                height: parent.height - root.titlebar-height;
                background: #171c29;

                SidebarEntry {
                    x: 12px;
                    y: 16px;
                    width: parent.width - 24px;
                    height: 50px;
                    icon: @image-url("icons/gear.svg");
                    label: "Настройки";
                    active: root.current-tab == 0;
                    clicked => {
                        root.select-tab(0);
                    }
                }

                SidebarEntry {
                    x: 12px;
                    y: 76px;
                    width: parent.width - 24px;
                    height: 50px;
                    icon: @image-url("icons/info.svg");
                    label: "О приложении";
                    active: root.current-tab == 1;
                    clicked => {
                        root.select-tab(1);
                    }
                }

                Text {
                    x: 32px;
                    y: parent.height - 44px;
                    width: 90px;
                    height: 20px;
                    text: root.app-version;
                    color: #c7cddd;
                    font-size: 14px;
                }

                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: #2c3241;
                }
            }

            content := Rectangle {
                x: root.sidebar-width;
                y: root.titlebar-height;
                width: parent.width - root.sidebar-width;
                height: parent.height - root.titlebar-height;
                background: #121825;

                basics-page := Rectangle {
                    visible: root.current-tab == 0;
                    width: parent.width;
                    height: parent.height;
                    background: #121825;

                    Text {
                        x: root.content-padding-x;
                        y: root.content-top;
                        width: 220px;
                        height: 42px;
                        text: "Настройки";
                        color: #ffffff;
                        font-size: 28px;
                        font-weight: 700;
                    }

                    Text {
                        x: root.content-padding-x;
                        y: 92px;
                        width: 320px;
                        height: 28px;
                        text: "Переключение раскладки";
                        color: #ffffff;
                        font-size: 17px;
                        font-weight: 700;
                    }

                    hotkey-card := Rectangle {
                        x: root.content-padding-x;
                        y: 140px;
                        width: parent.width - root.content-padding-x * 2;
                        height: 156px;
                        border-radius: 16px;
                        border-width: 1px;
                        border-color: #2f3748;
                        background: #171d2b;
                        clip: true;

                        ShortcutRow {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height / 2;
                            action-label: root.shortcut-actions[0].label;
                            shortcut-text: root.shortcut-actions[0].shortcut;
                            edit-requested => {
                                root.request-edit(0);
                            }
                        }

                        ShortcutRow {
                            x: 0;
                            y: parent.height / 2;
                            width: parent.width;
                            height: parent.height / 2;
                            show-top-divider: true;
                            action-label: root.shortcut-actions[1].label;
                            shortcut-text: root.shortcut-actions[1].shortcut;
                            edit-requested => {
                                root.request-edit(1);
                            }
                        }
                    }

                    autostart-card := Rectangle {
                        x: root.content-padding-x;
                        y: 356px;
                        width: parent.width - root.content-padding-x * 2;
                        height: 82px;
                        border-radius: 16px;
                        border-width: 1px;
                        border-color: #2f3748;
                        background: #171d2b;

                        Text {
                            x: 26px;
                            y: 0;
                            width: 180px;
                            height: parent.height;
                            text: "Автозапуск";
                            color: #ffffff;
                            font-size: 15px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }

                        ToggleSwitch {
                            x: parent.width - self.width - 24px;
                            y: parent.height * 0.5 - self.height * 0.5;
                            width: 66px;
                            height: 34px;
                            checked <=> root.autostart-enabled;
                        }
                    }
                }

                about-page := Rectangle {
                    visible: root.current-tab == 1;
                    width: parent.width;
                    height: parent.height;
                    background: #121825;

                    Text {
                        x: root.content-padding-x;
                        y: root.content-top;
                        width: 260px;
                        height: 42px;
                        text: "О приложении";
                        color: #ffffff;
                        font-size: 28px;
                        font-weight: 700;
                    }

                    Rectangle {
                        x: root.content-padding-x;
                        y: 104px;
                        width: parent.width - root.content-padding-x * 2;
                        height: 132px;
                        border-radius: 16px;
                        border-width: 1px;
                        border-color: #2f3748;
                        background: #171d2b;

                        Text {
                            x: 28px;
                            y: 24px;
                            width: parent.width - 56px;
                            height: 28px;
                            text: root.app-name;
                            color: #ffffff;
                            font-size: 22px;
                            font-weight: 700;
                        }

                        Text {
                            x: 28px;
                            y: 64px;
                            width: parent.width - 56px;
                            height: 24px;
                            text: root.app-version;
                            color: #c7cddd;
                            font-size: 16px;
                            font-weight: 500;
                        }
                    }
                }
            }
        }

        overlay := Rectangle {
            visible: root.editing-index >= 0;
            x: panel.x;
            y: panel.y;
            width: panel.width;
            height: panel.height;
            background: #05070db0;

            TouchArea {
                clicked => {
                    root.cancel-edit();
                }
            }

            dialog := Rectangle {
                x: parent.width * 0.5 - self.width * 0.5;
                y: parent.height * 0.5 - self.height * 0.5;
                width: 430px;
                height: 234px;
                forward-focus: shortcut-capture;
                border-radius: 18px;
                border-width: 1px;
                border-color: #363e51;
                background: #151c29;

                TouchArea {}

                shortcut-capture := FocusScope {
                    width: parent.width;
                    height: parent.height;
                    enabled: root.editing-index >= 0;
                    focus-on-click: false;
                    focus-on-tab-navigation: false;

                    key-pressed(event) => {
                        root.capture-shortcut(event.text, event.modifiers.control, event.modifiers.alt, event.modifiers.shift, event.modifiers.meta);
                        accept
                    }
                }

                Text {
                    x: 24px;
                    y: 22px;
                    width: parent.width - 48px;
                    height: 28px;
                    text: "Сочетание для \"" + root.editing-label + "\"";
                    color: #ffffff;
                    font-size: 19px;
                    font-weight: 700;
                }

                Text {
                    x: 24px;
                    y: 56px;
                    width: parent.width - 48px;
                    height: 22px;
                    text: "Нажмите сочетание клавиш";
                    color: #bfc7d7;
                    font-size: 14px;
                }

                HotkeyChip {
                    x: 24px;
                    y: 94px;
                    width: parent.width - 48px;
                    height: 54px;
                    value: root.pending-shortcut;
                }

                DialogButton {
                    x: parent.width - 216px;
                    y: parent.height - 56px;
                    width: 78px;
                    height: 38px;
                    label: "Отмена";
                    clicked => {
                        root.cancel-edit();
                    }
                }

                DialogButton {
                    x: parent.width - 124px;
                    y: parent.height - 56px;
                    width: 100px;
                    height: 38px;
                    label: "Сохранить";
                    primary: true;
                    action-enabled: root.pending-shortcut-valid;
                    clicked => {
                        root.accept-edit();
                    }
                }
            }
        }
    }

    changed editing-index => {
        if (root.editing-index >= 0) {
            dialog.focus();
        }
    }
}

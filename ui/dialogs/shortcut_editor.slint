import { DialogButton, HotkeyChip } from "../components/common.slint";

export component ShortcutEditorDialog inherits Rectangle {
    in property <int> editing-index: -1;
    in property <string> editing-label: "Последнее слово";
    in property <string> pending-shortcut: "Ctrl + Alt + 1";
    in property <bool> pending-shortcut-valid: true;

    callback cancel-edit();
    callback accept-edit();
    callback capture-shortcut(string, bool, bool, bool, bool);

    visible: root.editing-index >= 0;
    background: #05070db0;

    TouchArea {
        clicked => {
            root.cancel-edit();
        }
    }

    dialog := Rectangle {
        x: parent.width * 0.5 - self.width * 0.5;
        y: parent.height * 0.5 - self.height * 0.5;
        width: 430px;
        height: 234px;
        forward-focus: shortcut-capture;
        border-radius: 18px;
        border-width: 1px;
        border-color: #363e51;
        background: #151c29;

        TouchArea {}

        shortcut-capture := FocusScope {
            width: parent.width;
            height: parent.height;
            enabled: root.editing-index >= 0;
            focus-on-click: false;
            focus-on-tab-navigation: false;

            key-pressed(event) => {
                root.capture-shortcut(
                    event.text,
                    event.modifiers.control,
                    event.modifiers.alt,
                    event.modifiers.shift,
                    event.modifiers.meta
                );
                accept
            }
        }

        Text {
            x: 24px;
            y: 22px;
            width: parent.width - 48px;
            height: 28px;
            text: "Сочетание для \"" + root.editing-label + "\"";
            color: #ffffff;
            font-size: 19px;
            font-weight: 700;
        }

        Text {
            x: 24px;
            y: 56px;
            width: parent.width - 48px;
            height: 22px;
            text: "Нажмите сочетание клавиш";
            color: #bfc7d7;
            font-size: 14px;
        }

        HotkeyChip {
            x: 24px;
            y: 94px;
            width: parent.width - 48px;
            height: 54px;
            value: root.pending-shortcut;
        }

        DialogButton {
            x: parent.width - 216px;
            y: parent.height - 56px;
            width: 78px;
            height: 38px;
            label: "Отмена";
            clicked => {
                root.cancel-edit();
            }
        }

        DialogButton {
            x: parent.width - 124px;
            y: parent.height - 56px;
            width: 100px;
            height: 38px;
            label: "Сохранить";
            primary: true;
            action-enabled: root.pending-shortcut-valid;
            clicked => {
                root.accept-edit();
            }
        }
    }

    changed editing-index => {
        if (root.editing-index >= 0) {
            dialog.focus();
        }
    }
}
